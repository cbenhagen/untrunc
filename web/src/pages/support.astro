---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="Support · rsv.repair"
  description="Get help with rsv.repair and Sony .rsv file recovery."
>
  <main class="support-page flex-1 text-[#ededed]">
    <div class="support-inner container mx-auto max-w-5xl px-6 pt-10 pb-20 sm:pt-12 sm:pb-28">
      <header class="reveal" style="--d:0">
        <h1 class="page-title">Support</h1>
        <p class="page-sub">
          Questions about .rsv recovery or the web tool?<br class="hidden sm:inline" />
          Chat with us or email the team.
        </p>
      </header>

      <div class="support-grid">
        <section class="support-section reveal" style="--d:1">
          <h2 class="section-heading">Contact</h2>
          <p class="section-body">Open chat for the fastest help from our team.</p>
          <button type="button" class="chat-cta" data-rsv-open-chat>
            <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 28 32" aria-hidden="true" focusable="false">
              <path
                d="M28 32s-4.714-1.855-8.527-3.34H3.437C1.54 28.66 0 27.026 0 25.013V3.644C0 1.633 1.54 0 3.437 0h21.125c1.898 0 3.437 1.632 3.437 3.645v18.404H28V32zm-4.139-11.982a.88.88 0 00-1.292-.105c-.03.026-3.015 2.681-8.57 2.681-5.486 0-8.517-2.636-8.571-2.684a.88.88 0 00-1.29.107 1.01 1.01 0 00-.219.708.992.992 0 00.318.664c.142.128 3.537 3.15 9.762 3.15 6.226 0 9.621-3.022 9.763-3.15a.992.992 0 00.317-.664 1.01 1.01 0 00-.218-.707z"
              ></path>
            </svg>
            <span>Start chat support</span>
            <svg class="arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M3.5 8h9m0 0L8.5 4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </button>
          <p class="email-note">
            Prefer email?
            <a
              href="mailto:support@ottomatic.io?subject=rsv.repair%20Support&body=Hi%20Support%2C%0A%0AI%20need%20help%20with%20rsv.repair.%0A%0ABrowser%20%28name%20%2B%20version%29%3A%20%0ACamera%20body%20%28exact%20model%2C%20e.g.%20Sony%20FX3%29%3A%20%0AWhat%20I%20tried%3A%20%0AWhat%20happened%3A%20%0A"
              >support@ottomatic.io</a
            >
          </p>
          <div class="hint-box">
            <p class="hint-label">Include when you can:</p>
            <ul>
              <li>Browser and version</li>
              <li>Camera body (exact model)</li>
              <li>Whether the reference clip and .rsv are from the same camera</li>
            </ul>
          </div>
        </section>

        <section class="support-section reveal" style="--d:2">
          <h2 class="section-heading">Documentation</h2>
          <p class="section-body">Guides for .rsv files and how the tool works.</p>
          <div class="doc-list">
            <a href="/docs/" class="doc-link">
              <span class="doc-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
                  ></path>
                </svg>
              </span>
              <span class="doc-label">Documentation home</span>
              <span class="doc-arrow">&rsaquo;</span>
            </a>
            <a href="/docs/what-is-rsv/" class="doc-link">
              <span class="doc-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.12a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"
                  ></path>
                </svg>
              </span>
              <span class="doc-label">What is a .rsv file?</span>
              <span class="doc-arrow">&rsaquo;</span>
            </a>
            <a href="/docs/spot-rsv-early/" class="doc-link">
              <span class="doc-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
                  />
                </svg>
              </span>
              <span class="doc-label">Spot .rsv files early</span>
              <span class="doc-arrow">&rsaquo;</span>
            </a>
            <a href="/docs/using-the-web-app/" class="doc-link">
              <span class="doc-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.723 6.723 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.213-1.281z"
                  ></path>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </span>
              <span class="doc-label">Using the web app</span>
              <span class="doc-arrow">&rsaquo;</span>
            </a>
            <a href="/docs/rsv-format/" class="doc-link">
              <span class="doc-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </span>
              <span class="doc-label">RSV file format (technical)</span>
              <span class="doc-arrow">&rsaquo;</span>
            </a>
          </div>
        </section>
      </div>
    </div>
  </main>
</MarketingLayout>

<style>
  /* Match main app: #000, subtle grid, #1f1f1f borders, white primary button */
  .support-page {
    display: flex;
    flex-direction: column;
    background: #000000;
    position: relative;
  }

  .support-page::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .support-inner {
    position: relative;
    z-index: 1;
  }

  .reveal {
    opacity: 0;
    transform: translateY(14px);
    animation: fadeUp 0.55s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    animation-delay: calc(var(--d, 0) * 0.1s + 0.1s);
  }
  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: #ededed;
    margin-bottom: 0.75rem;
  }
  .page-sub {
    font-size: 0.95rem;
    line-height: 1.65;
    color: #a1a1a1;
    max-width: 28rem;
    margin-bottom: 3.5rem;
  }

  .support-grid {
    display: grid;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .support-grid {
      grid-template-columns: 5fr 6fr;
      gap: 5rem;
    }
  }

  .section-heading {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #666666;
    margin-bottom: 1rem;
  }
  .section-body {
    font-size: 0.875rem;
    color: #a1a1a1;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .chat-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    max-width: 22rem;
    padding: 0.65rem 1.1rem;
    min-height: 40px;
    border-radius: 8px;
    margin-bottom: 0.55rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #000000;
    background: #ffffff;
    border: 1px solid #ffffff;
    cursor: pointer;
    transition: opacity 150ms ease;
  }
  .chat-cta svg:first-of-type {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
  .chat-cta .arrow {
    width: 14px;
    height: 14px;
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 150ms ease,
      transform 150ms ease;
  }
  .chat-cta:hover {
    opacity: 0.92;
  }
  .chat-cta:hover .arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .email-note {
    margin-bottom: 1.2rem;
    font-size: 0.79rem;
    color: #666666;
  }
  .email-note a {
    color: #ededed;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .email-note a:hover {
    opacity: 0.85;
  }

  .hint-box {
    margin-top: 1.5rem;
    padding: 1rem 1.15rem;
    border-radius: 8px;
    border: 1px solid #1f1f1f;
    background: #0a0a0a;
  }
  .hint-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #a1a1a1;
    margin-bottom: 0.55rem;
  }
  .hint-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: #a1a1a1;
  }

  .doc-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .doc-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.9rem;
    border-radius: 8px;
    border: 1px solid #1f1f1f;
    background: #0a0a0a;
    color: #ededed;
    text-decoration: none;
    font-size: 0.875rem;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .doc-link:hover {
    background: #141414;
    border-color: #2e2e2e;
  }
  .doc-icon {
    flex: 0 0 1.25rem;
    color: #666666;
  }
  .doc-icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }
  .doc-label {
    flex: 1;
    font-weight: 500;
  }
  .doc-arrow {
    color: #666666;
    font-size: 1.1rem;
    line-height: 1;
  }
</style>
